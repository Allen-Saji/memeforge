# TwitterAPI.io key (optional — free sources work without it)
TWITTER_API_KEY=

# OpenAI API key (GPT-4o for creative packages, GPT-4o-mini for scoring)
OPENAI_API_KEY=

# Stability AI key (SDXL image generation, optional — falls back to DALL-E 3)
STABILITY_API_KEY=

# Reown (WalletConnect) project ID — free from cloud.reown.com
NEXT_PUBLIC_REOWN_PROJECT_ID=

# BNB Chain RPC (optional, defaults to https://bsc-dataseed.binance.org/)
BNB_RPC_URL=

# Set to "true" for manual scan mode (dev). Unset or "false" for auto-pipeline (prod).
MANUAL_SCAN=true

# Pipeline interval in milliseconds (default 300000 = 5 minutes, only used when MANUAL_SCAN=false)
PIPELINE_INTERVAL=300000

# Data directory (default ./data, set to /data on Railway with persistent volume)
DATA_DIR=./data

# Basic auth password for demo (optional)
AUTH_PASSWORD=

# Set to "false" to use live SSE instead of mock data (default: mock mode)
NEXT_PUBLIC_USE_MOCK=true
